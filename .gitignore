# Build
/build
/app/build
/.gradle
/local.properties
*.apk

# IDE
/.idea
*.iml
.DS_Store

# ObjectBox model — regenerated by kapt
app/src/main/objectbox-models/default.json

# CMake build cache (leftover from parent repo copy)
app/.cxx/

# Cursor/Windsurf/Kiro IDE configs (not needed for public repo)
.cursorrules
.windsurfrules
.kiro/
.opencode.json

# Other IDE agents
AGENTS.md
GEMINI.md

# Claude Code project config (has MCP tool references)
.claude/
.mcp.json

# Archive doc
archive/

# Corpus: canonical version lives in corpus/dist/manuales_base_v6.json (tracked in git).
# The assets copy below is identical — kept untracked to avoid double-storing 16 MB in git.
# To restore: cp corpus/dist/manuales_base_v6.json app/src/main/assets/manuales_base.json
app/src/main/assets/manuales_base.json

# Pipeline virtualenv / byte-compiled
pipeline/__pycache__/
pipeline/*.egg-info/
pipeline/.venv/
pipeline/venv/

# Large model files — download separately (see README)
*.gguf
*.litertlm
*.tflite
# multilingual-e5-small ONNX (113 MB) — download from HuggingFace: intfloat/multilingual-e5-small
app/src/main/assets/models/multilingual-e5-small.onnx
